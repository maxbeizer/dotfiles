#!/usr/bin/env bash
#
# tmux-nav: Interactive tmux session/window/pane navigator
#
# Usage: tmux-nav [sessions|windows]
#   sessions  - Browse sessions, preview windows+panes
#   windows   - Browse windows in current session, preview pane content
#
# Keybindings (shown in header):
#   Enter     - Switch to selected
#   Ctrl-N    - New window/session
#   Ctrl-X    - Kill selected
#   Escape    - Cancel
#

set -e

export PATH="$HOME/.local/bin:$HOME/.fzf/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

mode="${1:-sessions}"

case "$mode" in
  sessions)
    result=$(tmux list-sessions -F '#{session_name}' | \
      fzf --reverse \
        --header='enter=switch  ctrl-n=new  ctrl-x=kill' \
        --preview='
          tmux list-windows -t {} -F "  #{window_index}:#{window_name} (#{window_panes} panes)#{?window_bell_flag, 🔔,}#{?window_activity_flag, •,} #{?window_active,◀,}" 2>/dev/null
          echo ""
          echo "── Active pane ──"
          tmux capture-pane -t {}:1 -p 2>/dev/null | tail -15
        ' \
        --preview-window=right:50% \
        --expect=ctrl-n,ctrl-x \
      ) || exit 0

    key=$(echo "$result" | head -1)
    selection=$(echo "$result" | tail -1)

    case "$key" in
      ctrl-n)
        # Prompt for new session name
        read -p "New session name: " name
        [ -n "$name" ] && tmux new-session -d -s "$name" && tmux switch-client -t "$name"
        ;;
      ctrl-x)
        [ -n "$selection" ] && tmux kill-session -t "$selection" 2>/dev/null
        ;;
      *)
        [ -n "$selection" ] && tmux switch-client -t "$selection"
        ;;
    esac
    ;;

  windows)
    result=$(tmux list-windows -a -F '#{window_activity}	#{session_name}:#{window_index}	#{window_name}	#{?window_bell_flag,🔔 ,}#{?window_activity_flag,• ,}#{?window_active,◀ ,}	#{session_name}' | \
      sort -rn | \
      awk -F'	' '{
        printf "%s\t%-18s %s %s\n", $2, $3, $4, $5
      }' | \
      fzf --reverse \
        --header='enter=switch  ctrl-n=new  ctrl-x=kill' \
        --with-nth=2.. \
        --delimiter='	' \
        --preview='
          target=$(echo {} | cut -f1)
          echo "── Panes ──"
          tmux list-panes -t "$target" -F "  #{pane_index}: #{pane_current_command}  #{pane_current_path}" 2>/dev/null
          echo ""
          echo "── Content ──"
          tmux capture-pane -t "$target" -p 2>/dev/null | tail -25
        ' \
        --preview-window=right:55% \
        --expect=ctrl-n,ctrl-x \
      ) || exit 0

    key=$(echo "$result" | head -1)
    selection=$(echo "$result" | tail -1)
    target=$(echo "$selection" | cut -f1)

    case "$key" in
      ctrl-n)
        session=$(echo "$target" | cut -d: -f1)
        tmux new-window -t "$session"
        ;;
      ctrl-x)
        [ -n "$target" ] && tmux kill-window -t "$target" 2>/dev/null
        ;;
      *)
        [ -n "$target" ] && tmux switch-client -t "$target"
        ;;
    esac
    ;;
esac
