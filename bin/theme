#!/bin/bash
#
# Switch color theme across Ghostty, tmux, nvim, and Starship.
# Idempotent — safe to run repeatedly.
#
# Usage:
#   theme solarized    # Solarized Dark
#   theme mocha        # Catppuccin Mocha
#   theme              # show current theme
#

set -eu

THEME_FILE="${HOME}/.config/theme"

current_theme() {
  cat "$THEME_FILE" 2>/dev/null || echo "solarized"
}

set_ghostty() {
  local config="${HOME}/.config/ghostty/config"
  [ -f "$config" ] || return 0

  case "$1" in
    solarized)
      sed -i.bak 's/^theme = .*/theme = iTerm2 Solarized Dark/' "$config"
      ;;
    mocha)
      sed -i.bak 's/^theme = .*/theme = catppuccin-mocha/' "$config"
      ;;
  esac
  rm -f "${config}.bak"
}

set_tmux() {
  command -v tmux >/dev/null 2>&1 || return 0

  case "$1" in
    solarized)
      # pane backgrounds
      tmux set -g window-style 'bg=#001a26'
      tmux set -g window-active-style 'bg=#002b36'
      # pane borders
      tmux set -g pane-active-border-style 'fg=#859900,bold'
      tmux set -g pane-border-style 'fg=#586e75'
      # status bar
      tmux set -g status-style 'bg=#073642,fg=#839496'
      tmux set -g window-status-format '#[fg=#586e75] #I:#W#{?window_bell_flag,🔔,#{?window_activity_flag,•,}} '
      tmux set -g window-status-current-format '#[fg=#eee8d5,bg=#268bd2,bold] #I:#W '
      tmux set -g window-status-bell-style 'fg=#dc322f,bold'
      tmux set -g window-status-activity-style 'fg=#b58900'
      tmux set -g status-right '#[fg=#586e75]#{?#{==:#{pane_current_command},zsh},#(cd #{pane_current_path} && git branch --show-current 2>/dev/null),} #[fg=#268bd2,bold] #{session_name}'
      ;;
    mocha)
      # pane backgrounds
      tmux set -g window-style 'bg=#181825'
      tmux set -g window-active-style 'bg=#1e1e2e'
      # pane borders
      tmux set -g pane-active-border-style 'fg=#89b4fa,bold'
      tmux set -g pane-border-style 'fg=#585b70'
      # status bar
      tmux set -g status-style 'bg=#181825,fg=#cdd6f4'
      tmux set -g window-status-format '#[fg=#585b70] #I:#W#{?window_bell_flag,🔔,#{?window_activity_flag,•,}} '
      tmux set -g window-status-current-format '#[fg=#1e1e2e,bg=#89b4fa,bold] #I:#W '
      tmux set -g window-status-bell-style 'fg=#f38ba8,bold'
      tmux set -g window-status-activity-style 'fg=#f9e2af'
      tmux set -g status-right '#[fg=#585b70]#{?#{==:#{pane_current_command},zsh},#(cd #{pane_current_path} && git branch --show-current 2>/dev/null),} #[fg=#89b4fa,bold] #{session_name}'
      ;;
  esac
  # suppress errors for headless/no-server
  true
}

set_nvim() {
  command -v nvim >/dev/null 2>&1 || return 0

  local cmd
  case "$1" in
    solarized) cmd="<Cmd>colorscheme NeoSolarized<CR>" ;;
    mocha) cmd="<Cmd>lua require('lazy').load({plugins = {'catppuccin'}})<CR><Cmd>colorscheme catppuccin-mocha<CR>" ;;
  esac

  # macOS: sockets in $TMPDIR/nvim.*/  Linux: /tmp/nvim.*/
  local dir="${TMPDIR:-/tmp}"
  for sock in "$dir"/nvim.*/*/nvim.*.0 "$dir"/nvim.*/0 /tmp/nvim.*/0; do
    [ -S "$sock" ] 2>/dev/null && nvim --server "$sock" --remote-send "$cmd" 2>/dev/null &
  done
  wait 2>/dev/null
}

if [ $# -eq 0 ]; then
  echo "Current theme: $(current_theme)"
  exit 0
fi

case "$1" in
  solarized|mocha)
    echo "$1" > "$THEME_FILE"
    set_ghostty "$1"
    set_tmux "$1"
    set_nvim "$1"
    echo "Switched to $1"
    echo "  Note: Restart Ghostty for terminal theme to take effect."
    ;;
  *)
    echo "Usage: theme [solarized|mocha]" >&2
    exit 1
    ;;
esac
