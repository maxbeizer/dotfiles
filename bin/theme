#!/bin/bash
#
# Switch color theme across Ghostty, tmux, nvim, television, and Starship.
# Idempotent — safe to run repeatedly.
#
# Usage:
#   theme solarized    # Solarized Dark
#   theme mocha        # Catppuccin Mocha
#   theme              # show current theme
#

set -eu

THEME_FILE="${HOME}/.config/theme"

current_theme() {
  cat "$THEME_FILE" 2>/dev/null || echo "solarized"
}

set_ghostty() {
  local config="${HOME}/.config/ghostty/config"
  [ -f "$config" ] || return 0

  # Resolve symlink — sed -i can't edit symlinks
  local real_config
  real_config=$(readlink "$config" 2>/dev/null || echo "$config")

  case "$1" in
    solarized)
      sed -i.bak 's/^theme = .*/theme = Solarized Dark Higher Contrast/' "$real_config"
      ;;
    mocha)
      sed -i.bak 's/^theme = .*/theme = Catppuccin Mocha/' "$real_config"
      ;;
  esac
  rm -f "${real_config}.bak"
}

set_tmux() {
  command -v tmux >/dev/null 2>&1 || return 0

  case "$1" in
    solarized)
      # pane backgrounds (bigger gap between active/inactive)
      tmux set -g window-style 'bg=#00141f'
      tmux set -g window-active-style 'bg=#002b36'
      # pane borders
      tmux set -g pane-active-border-style 'fg=#859900,bold'
      tmux set -g pane-border-style 'fg=#586e75'
      # status bar
      tmux set -g status-style 'bg=#073642,fg=#93a1a1'
      tmux set -g window-status-format '#[fg=#657b83] #I:#W#{?window_bell_flag,🔔,#{?window_activity_flag,•,}} '
      tmux set -g window-status-current-format '#[fg=#eee8d5,bg=#268bd2,bold] #I:#W#{?window_zoomed_flag, 🔍,} '
      tmux set -g window-status-bell-style 'fg=#dc322f,bold'
      tmux set -g window-status-activity-style 'fg=#b58900'
      tmux set -g status-right '#[fg=#586e75]#{?window_zoomed_flag,🔍 ,}#{?#{==:#{pane_current_command},zsh},#(cd #{pane_current_path} && git branch --show-current 2>/dev/null),} #[fg=#268bd2,bold] #{session_name}'
      ;;
    mocha)
      # pane backgrounds (bigger gap between active/inactive)
      tmux set -g window-style 'bg=#11111b'
      tmux set -g window-active-style 'bg=#1e1e2e'
      # pane borders
      tmux set -g pane-active-border-style 'fg=#89b4fa,bold'
      tmux set -g pane-border-style 'fg=#585b70'
      # status bar
      tmux set -g status-style 'bg=#11111b,fg=#cdd6f4'
      tmux set -g window-status-format '#[fg=#7f849c] #I:#W#{?window_bell_flag,🔔,#{?window_activity_flag,•,}} '
      tmux set -g window-status-current-format '#[fg=#1e1e2e,bg=#89b4fa,bold] #I:#W#{?window_zoomed_flag, 🔍,} '
      tmux set -g window-status-bell-style 'fg=#f38ba8,bold'
      tmux set -g window-status-activity-style 'fg=#f9e2af'
      tmux set -g status-right '#[fg=#585b70]#{?window_zoomed_flag,🔍 ,}#{?#{==:#{pane_current_command},zsh},#(cd #{pane_current_path} && git branch --show-current 2>/dev/null),} #[fg=#89b4fa,bold] #{session_name}'
      ;;
  esac
  # suppress errors for headless/no-server
  true
}

set_nvim() {
  command -v nvim >/dev/null 2>&1 || return 0

  local cmd
  case "$1" in
    solarized) cmd="<Cmd>colorscheme NeoSolarized<CR>" ;;
    mocha) cmd="<Cmd>lua require('lazy').load({plugins = {'catppuccin'}})<CR><Cmd>colorscheme catppuccin-mocha<CR>" ;;
  esac

  # macOS: sockets in $TMPDIR/nvim.*/  Linux: /tmp/nvim.*/
  local dir="${TMPDIR:-/tmp}"
  for sock in /tmp/nvim-*.sock "$dir"/nvim.*/*/nvim.*.0 "$dir"/nvim.*/0 /tmp/nvim.*/0; do
    if [ -S "$sock" ] 2>/dev/null; then
      nvim --server "$sock" --remote-send "$cmd" &>/dev/null &
    fi
  done
}

set_posting() {
  local config="${HOME}/.config/posting/config.yaml"
  mkdir -p "$(dirname "$config")"

  case "$1" in
    solarized) local posting_theme="solarized-dark" ;;
    mocha) local posting_theme="catppuccin-mocha" ;;
  esac

  if [ -f "$config" ]; then
    if grep -q '^theme:' "$config"; then
      sed -i.bak "s/^theme:.*/theme: \"$posting_theme\"/" "$config"
      rm -f "${config}.bak"
    else
      echo "theme: \"$posting_theme\"" >> "$config"
    fi
  else
    echo "theme: \"$posting_theme\"" > "$config"
  fi
}

set_television() {
  local config="${HOME}/.config/television/config.toml"
  [ -f "$config" ] || return 0

  case "$1" in
    solarized) local tv_theme="solarized-dark" ;;
    mocha) local tv_theme="catppuccin" ;;
  esac

  if grep -q '^theme = ' "$config"; then
    sed -i.bak "s/^theme = .*/theme = \"$tv_theme\"/" "$config"
    rm -f "${config}.bak"
  fi
}

if [ $# -eq 0 ]; then
  echo "Current theme: $(current_theme)"
  exit 0
fi

case "$1" in
  solarized|mocha)
    echo "$1" > "$THEME_FILE"
    set_ghostty "$1"
    set_tmux "$1"
    set_nvim "$1"
    set_posting "$1"
    set_television "$1"
    echo "Switched to $1"
    ;;
  *)
    echo "Usage: theme [solarized|mocha]" >&2
    exit 1
    ;;
esac
