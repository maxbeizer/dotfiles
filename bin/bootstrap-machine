#!/bin/sh
#
# Bootstrap a fresh machine with these dotfiles.
# Self-contained — no rcm, no thoughtbot/dotfiles dependency.
#
# Usage:
#   ~/dotfiles-local/bin/bootstrap-machine [--dry-run] [--skip-verify]
#

set -eu

dry_run=0
skip_verify=0

while [ $# -gt 0 ]; do
  case "$1" in
    -n|--dry-run) dry_run=1 ;;
    --skip-verify) skip_verify=1 ;;
    -h|--help)
      cat <<'EOF'
Usage: bootstrap-machine [--dry-run] [--skip-verify]

Bootstraps dotfiles on a fresh machine:
  - clones dotfiles repo if needed
  - runs install.sh to symlink everything
  - optionally verifies startup
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
  shift
done

run() {
  echo "+ $*"
  if [ "$dry_run" -eq 0 ]; then
    "$@"
  fi
}

DOTFILES_URL="${DOTFILES_URL:-https://github.com/maxbeizer/dotfiles.git}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

if ! command -v git >/dev/null 2>&1; then
  echo "git is required." >&2
  exit 1
fi

if [ ! -d "$DOTFILES_DIR/.git" ]; then
  run git clone "$DOTFILES_URL" "$DOTFILES_DIR"
fi

echo "Running install.sh..."
if [ "$dry_run" -eq 1 ]; then
  run "$DOTFILES_DIR/install.sh" --dry-run
else
  run "$DOTFILES_DIR/install.sh"
fi

if [ "$skip_verify" -eq 0 ]; then
  if [ "$dry_run" -eq 1 ]; then
    echo "+ zsh -lic 'echo shell-ok'"
  else
    echo "Verifying..."
    if zsh -lic 'echo shell-ok' >/dev/null 2>&1; then
      echo "  ✓ shell starts cleanly"
    else
      echo "  ✗ shell startup has errors" >&2
    fi
  fi
fi

echo ""
echo "Bootstrap complete ✓"
