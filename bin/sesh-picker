#!/usr/bin/env bash
#
# sesh-picker: Session picker with bell indicators (bell-only, not activity)
#
# Usage: sesh-picker [--list]
#   --list  Print session list and exit (used by fzf reload)
#
export PATH="/opt/homebrew/bin:$PATH"

SELF="$(realpath "$0")"

list_sessions() {
  # Bell sessions first (bell only, not activity), then other tmux sessions
  local bell_sessions=() other_sessions=()
  while IFS= read -r session; do
    has_bell=$(tmux list-windows -t "$session" -F '#{window_bell_flag}' 2>/dev/null | grep -c 1)
    if [ "$has_bell" -gt 0 ]; then
      bell_sessions+=("🔔 $session")
    else
      other_sessions+=("$session")
    fi
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)
  printf '%s\n' "${bell_sessions[@]}" "${other_sessions[@]}"
  sesh list -z -c
}

if [ "${1-}" = "--list" ]; then
  list_sessions
  exit 0
fi

strip_bell() {
  sed 's/^🔔 //'
}

pick=$(list_sessions | fzf --reverse --ansi \
  --preview 'sesh preview "$(echo {} | sed "s/^🔔 //")"' \
  --header 'enter=connect  ctrl-d=kill' \
  --bind "ctrl-d:execute-silent(tmux kill-session -t \$(echo {} | sed 's/^🔔 //'))+reload($SELF --list)")

[ -n "$pick" ] && sesh connect "$(echo "$pick" | strip_bell)"
