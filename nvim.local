" Ensure homebrew is on PATH before any plugins load
if isdirectory('/opt/homebrew/bin')
  let $PATH = '/opt/homebrew/bin:' . $PATH
endif

" Enable filetype detection, plugins, and indent
filetype plugin indent on
syntax on

" Bootstrap Lua config
lua << LUAEOF
local ok, maxbeizer = pcall(require, 'maxbeizer')
if ok and maxbeizer.setup then
  maxbeizer.setup()
end
LUAEOF
